{
  "sources": [
    {
      "storeName": "Paknsave",
      "storeLocation": "Auckland",
      "engine": "playwright",
      "channel": "chromium",
      "headless": false,
      "storageStatePath": "./tmp/paknsave-storage.json",
      "url": "https://www.paknsave.co.nz/shop/search/products?search=chicken",
      "waitForSelector": ".fs-product-card, [data-testid='product-card'], .product-card",
      "rowSelector": ".fs-product-card, [data-testid='product-card'], .product-card",
      "nameSelector": ".fs-product-card__title, [data-testid='product-title'], .product-title, .product-name",
      "priceSelector": ".fs-product-card__price, [data-testid='price-dollars'], .price, .product-price",
      "unitSelector": ".fs-product-card__subtext, [data-testid='product-subtitle'], .product-subtitle",
      "delayMs": 1500,
      "debugHtmlPath": "./tmp/paknsave-debug.html",
      "unit": "unit",
      "category": "general"
    },
    {
      "storeName": "New World",
      "storeLocation": "Auckland",
      "url": "https://example.com/newworld-prices",
      "rowSelector": "table tbody tr",
      "nameSelector": "td:nth-child(1)",
      "priceSelector": "td:nth-child(2)",
      "unitSelector": "td:nth-child(3)",
      "category": "general"
    }
  ]
}
