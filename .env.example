# MongoDB
# Create a MongoDB Atlas project and database, then paste the connection string below.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster-name.mongodb.net/database-name

# Auth.js / NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-new-random-secret
NEXTAUTH_URL=http://localhost:3000

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
# Create a Stripe account, then use the Dashboard or Stripe CLI to get these values.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Resend
# Create a Resend account and API key, then verify a sending domain or use onboarding@resend.dev for testing.
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Your App <onboarding@resend.dev>

# Internal server-to-server protection for /api/send-email
# Generate with: openssl rand -base64 32
INTERNAL_API_KEY=replace-with-a-new-random-secret

# Protect scheduled scraping endpoint (/api/cron/scrape-prices)
# Generate with: openssl rand -base64 32
CRON_SECRET=replace-with-a-new-random-secret

# Optional for hosted cron runs: JSON from tmp/paknsave-storage.json (single line)
PAKNSAVE_STORAGE_STATE_JSON=

# Optional admin seed / app metadata
ADMIN_EMAIL=you@example.com
